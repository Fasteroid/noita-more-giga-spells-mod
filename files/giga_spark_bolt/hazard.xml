<Entity name="$projectile_default" tags="projectile_player" >

	<Base file="data/entities/base_projectile.xml" >
		<VelocityComponent
			gravity_y="0"
			air_friction="0.5"
			mass="0.02"
			>
		</VelocityComponent>
	</Base>

	<ProjectileComponent 
		_enabled="1" 
		lob_min="0.5"
		lob_max="0.7"
		speed_min="70"
		speed_max="80"
		friction="1"
		on_death_gfx_leave_sprite="0" 
		on_collision_die="1"
		lifetime="40"
		damage="0.01"
		bounce_always="1"
		bounces_left="3"
		bounce_energy="0.5"
		lifetime_randomness="7"
		ragdoll_force_multiplier="0.01"
		hit_particle_force_multiplier="0.1"
		knockback_force="5.0"
		physics_impulse_coeff="2000"
		friendly_fire="1"
		>
		<damage_by_type
			slice="0"
		>
		</damage_by_type>
		<config_explosion>
		</config_explosion>
	</ProjectileComponent>

  <ParticleEmitterComponent 
		emitted_material_name="plasma_fading_pink"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="0"
		x_pos_offset_max="0"
		y_pos_offset_min="0"
		y_pos_offset_max="0"
		gravity.y="0"
		x_vel_min="-3"
		x_vel_max="3"
		y_vel_min="-3"
		y_vel_max="3"
		count_min="1"
		count_max="1"
		lifetime_min="0.1"
		lifetime_max="0.2"
		airflow_force="1.0"
		airflow_time="0.401"
		airflow_scale="0.25"
		is_trail="1"
		create_real_particles="0"
		emit_cosmetic_particles="1"
		render_on_grid="1"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		fade_based_on_lifetime="1"
		is_emitting="1" >
	</ParticleEmitterComponent>

	<LuaComponent
		script_source_file="data/scripts/projectiles/chaotic_arc.lua"
		execute_every_n_frame="2"
		>
	</LuaComponent>

	<HomingComponent
		target_who_shot="1"
		homing_targeting_coeff="30.0"
		homing_velocity_multiplier="0.95"
		detect_distance="50"
	>
	</HomingComponent>

</Entity>


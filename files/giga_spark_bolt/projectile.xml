<Entity name="$projectile_default" tags="projectile_player" >

	<Base file="data/entities/base_projectile.xml" >
	<VelocityComponent
		gravity_y="200"
		air_friction="0.8"
		mass="0.04"
		>
	</VelocityComponent>
	</Base>

	<ProjectileComponent 
		_enabled="1" 
		lob_min="0.5"
		lob_max="0.7"
		speed_min="650"
		speed_max="750"
		friction="1"
		direction_random_rad="0.00"
		on_death_explode="1"
		on_death_gfx_leave_sprite="0" 
		on_lifetime_out_explode="1"
		explosion_dont_damage_shooter="0"
		on_collision_die="1"
		lifetime="80"
		damage="0.5"
		velocity_sets_scale="1"
		lifetime_randomness="7"
		ragdoll_force_multiplier="0.02"
		hit_particle_force_multiplier="0.1"
		muzzle_flash_file="data/entities/particles/muzzle_flashes/muzzle_flash_large_pink.xml"
		shoot_light_flash_r="255"
		shoot_light_flash_g="160"
		shoot_light_flash_b="255"
		shoot_light_flash_radius="128" 
		knockback_force="0"
		friendly_fire="1"
		physics_impulse_coeff="800"
		>
		<config_explosion
			never_cache="1" 
			damage="0.1"
			camera_shake="2.0" 
			explosion_radius="8" 
			explosion_sprite="data/particles/explosion_016_plasma_pink.xml" 
			explosion_sprite_lifetime="0" 
			create_cell_probability="0" 
			hole_destroy_liquid="0" 
			hole_enabled="1" 
			ray_energy="300000"
			max_durability_to_destroy="11"
			particle_effect="0" 
			damage_mortals="1"
			physics_explosion_power.min="0.5"
			physics_explosion_power.max="0.8" 
			physics_throw_enabled="1" 
			shake_vegetation="1" 
			sparks_count_max="20" 
			sparks_count_min="7" 
			sparks_enabled="0"	
			material_sparks_enabled="1"
			material_sparks_count_max="2"
			material_sparks_count_min="0" 
			light_enabled="0" 
			stains_enabled="1"
			stains_radius="8" 
			audio_event_name="explosions/gunpowder">
		</config_explosion>
	</ProjectileComponent>
	
	<SpriteComponent 
		_enabled="1" 
		alpha="1" 
		image_file="mods/more_giga_spells/files/giga_spark_bolt/sprite.xml" 
		next_rect_animation="default"
		rect_animation="default"
		additive="1"
	>
	</SpriteComponent>

	<!-- dense emitter -->
	<ParticleEmitterComponent 
		emitted_material_name="plasma_fading_pink"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-2"
		x_pos_offset_max="2"
		y_pos_offset_min="-2"
		y_pos_offset_max="2"
		x_vel_min="0"
		x_vel_max="0"
		y_vel_min="0"
		y_vel_max="0"
		gravity.y="0.0"
		count_min="4"
		count_max="8"
		lifetime_min="0.6"
		lifetime_max="0.8"
		is_trail="1"
		trail_gap="1.0"
		render_on_grid="1"
		fade_based_on_lifetime="1"
		airflow_force="10.5"
		airflow_time="1.401"
		airflow_scale="0.05"
		emission_interval_min_frames="1"
		emission_interval_max_frames="1"
		emit_cosmetic_particles="1"
		create_real_particles="0"
		is_emitting="1" >
	</ParticleEmitterComponent>
	
	<!-- sparse emitter -->
	<ParticleEmitterComponent 
		emitted_material_name="plasma_fading_pink"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-2"
		x_pos_offset_max="2"
		y_pos_offset_min="-2"
		y_pos_offset_max="2"
		x_vel_min="20"
		x_vel_max="40"
		y_vel_min="20"
		y_vel_max="40"
		gravity.y="0.0"
		count_min="1"
		count_max="4"
		lifetime_min="0.6"
		lifetime_max="1.2"
		is_trail="0"
		trail_gap="4.0"
		render_on_grid="1"
		fade_based_on_lifetime="1"
		airflow_force="1.5"
		airflow_time="0.401"
		airflow_scale="0.05"
		emission_interval_min_frames="1"
		emission_interval_max_frames="10"
		emit_cosmetic_particles="1"
		create_real_particles="0"
		is_emitting="1" >
	</ParticleEmitterComponent>
	
		<!-- very sparse emitter -->
	<ParticleEmitterComponent 
		emitted_material_name="plasma_fading_pink"
		offset.x="0"
		offset.y="0"
		x_pos_offset_min="-2"
		x_pos_offset_max="2"
		y_pos_offset_min="-2"
		y_pos_offset_max="2"
		x_vel_min="60"
		x_vel_max="60"
		y_vel_min="60"
		y_vel_max="60"
		gravity.y="0.0"
		count_min="1"
		count_max="1"
		lifetime_min="1.4"
		lifetime_max="1.5"
		is_trail="0"
		trail_gap="4.0"
		render_on_grid="1"
		fade_based_on_lifetime="1"
		airflow_force="0.5"
		airflow_time="0.5"
		airflow_scale="0.05"
		emission_interval_min_frames="10"
		emission_interval_max_frames="20"
		emit_cosmetic_particles="1"
		create_real_particles="0"
		is_emitting="1" >
	</ParticleEmitterComponent>

	<LightComponent 
		_enabled="1" 
		r="255"
		g="40"
		b="255"
		radius="60">
	</LightComponent>

	<AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		event_root="player_projectiles/bullet_fire_heavy">
	</AudioComponent>

	<AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		event_root="player_projectiles/bullet_fire_heavy">
	</AudioComponent>

	<AudioComponent
		file="data/audio/Desktop/projectiles.bank"
		event_root="player_projectiles/bullet"
		>
	</AudioComponent>
	
	<VariableStorageComponent
		name="projectile_file"
		value_string="mods/more_giga_spells/files/giga_spark_bolt/projectile.xml">
	</VariableStorageComponent>

	<LuaComponent 
		_enabled="1" 
		script_source_file="mods/more_giga_spells/files/giga_spark_bolt/projectile.lua" 
		execute_every_n_frame="1">
	</LuaComponent>

</Entity>